{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/*.md"
  ],

  "permission": {
    "*": "allow",
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git push *": "ask",
      "git push": "ask",
      "shutdown *": "deny",
      "reboot *": "deny",
      "mkfs *": "deny",
      "dd if=*": "deny"
    }
  }
}
